{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ETB Save Manager",
  "version": "3.3.0",
  "identifier": "com.admin.etbsavemanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ETB Save Manager",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "additionalBrowserArgs": "--disable-software-rasterizer --enable-gpu-rasterization --force-gpu-rasterization",
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https:; script-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "embedBootstrapper"
      },
      "nsis": {
        "languages": ["English", "SimpChinese", "TradChinese"],
        "displayLanguageSelector": true
      }
    },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5MDA1MkJENzI4QkI1NEUKUldST3RZdHl2VklBeVNBazlsNFFhc2dqMnMvUU91UU5QZCs1aEpxNHA0TGZUaHEvMW00YUpVZDIK",
      "endpoints": ["https://github.com/Eververdants/ETBSaveManager/releases/latest/download/latest.json"]
    }
  }
}
